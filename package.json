{
	"name": "macscp",
	"version": "0.1.0",
	"type": "module",
	"main": "electron/main.js",
	"scripts": {
		"dev": "concurrently -k -n VITE,ELECTRON -c cyan,yellow \"vite\" \"wait-on http://localhost:5374 && electron .\"",
		"build": "vite build",
		"build:mac": "npm run build && electron-builder --mac --arm64",
		"test": "node --experimental-vm-modules node_modules/.bin/jest --passWithNoTests",
		"test:e2e": "docker exec macscp-sftp-1 chown testuser:users /home/testuser/upload 2>/dev/null || true && playwright test"
	},
	"devDependencies": {
		"@electron/notarize": "^2.2.1",
		"@playwright/test": "^1.43.0",
		"@vitejs/plugin-react": "^4.2.1",
		"concurrently": "^8.2.2",
		"electron": "^29.0.0",
		"electron-builder": "^24.13.3",
		"jest": "^29.7.0",
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"vite": "^5.2.0",
		"wait-on": "^7.2.0"
	},
	"dependencies": {
		"electron-store": "^8.2.0",
		"keytar": "^7.9.0",
		"ssh2": "^1.17.0",
		"ssh2-sftp-client": "^10.0.3",
		"ssh-config": "^4.4.1",
		"basic-ftp": "^5.0.5",
		"webdav": "^5.7.1",
		"@aws-sdk/client-s3": "^3.575.0",
		"chokidar": "^3.6.0"
	},
	"jest": {
		"extensionsToTreatAsEsm": [".jsx"],
		"transform": {},
		"testPathIgnorePatterns": ["/node_modules/", "/e2e/"]
	}
}
